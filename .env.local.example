# Supabase (PUBLIC - safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://osyrwsbruydcyhdjvjpv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase (SERVER ONLY - never exposed)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=<from Supabase dashboard → Settings → API → JWT Secret>

# Railway backend (FastAPI)
NEXT_PUBLIC_RAILWAY_API=http://localhost:8000
NEXT_PUBLIC_RAILWAY_WS=ws://localhost:8000/v1/voice/ws

# Picovoice (PUBLIC - WASM license key, safe)
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=

# Telemetry (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=

# Paddle (billing — Sprint 19 / M36)
# We use Paddle Merchant of Record (not Stripe). See:
# https://developer.paddle.com/concepts/api-keys
NEXT_PUBLIC_PADDLE_VENDOR_ID=
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# UX v2 feature flags (set to 'true' to activate)
NEXT_PUBLIC_UX_V2_SHELL=false
NEXT_PUBLIC_UX_V2_HOME=false
NEXT_PUBLIC_UX_V2_COMPOSER=false
NEXT_PUBLIC_UX_V2_MATTER=false
NEXT_PUBLIC_UX_V2_CANVAS=false

# ─── Document Generation V2 (Sprint L-DOC) ────────────────────────────────────
# Feature flags para el nuevo flow de generación de documentos legales
NEXT_PUBLIC_DOC_GEN_V2_ENABLED=false
NEXT_PUBLIC_DOC_STREAMING_CANVAS_ENABLED=false
NEXT_PUBLIC_DOC_INLINE_PARAMS_FORM=false
NEXT_PUBLIC_DOC_CITATION_BADGES_INLINE=false

# Backend toggles (server only)
BACKEND_USE_BINARY_EMBEDDINGS=false
BACKEND_USE_SEMANTIC_CACHE=false
BACKEND_USE_SELF_CRITIQUE_LOOP=false
INGEST_WORKER_ENABLED=false

# Canary deployment (CSV de user_ids con acceso al nuevo flow)
DOC_GEN_USER_ALLOWLIST=

# ─── OpenAI (modelos economy tier) ────────────────────────────────────────────
# Stack: GPT-4o-mini (drafting/router/extractor), text-embedding-3-small (RAG),
# o3-mini (judge/critic crítico)
OPENAI_API_KEY=
OPENAI_MODEL_DRAFTER=gpt-4o-mini
OPENAI_MODEL_ROUTER=gpt-4o-mini
OPENAI_MODEL_EXTRACTOR=gpt-4o-mini
OPENAI_MODEL_JUDGE=o3-mini
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small

# ─── Cloudflare R2 (storage corpus legal) ─────────────────────────────────────
# Free tier: 10 GB + 0 egress fees
# IMPORTANTE: el token NUNCA va a git, solo .env.local
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=lexai-corpus
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── Hugging Face Datasets (backup nocturno) ──────────────────────────────────
HUGGINGFACE_TOKEN=
HF_DATASET_REPO=

# ─── Observability ────────────────────────────────────────────────────────────
HELICONE_API_KEY=
SENTRY_DSN_INGEST=
